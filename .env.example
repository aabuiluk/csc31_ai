# ---------------------------------------------------------------------------
# Токен OpenAI (API key)
# ---------------------------------------------------------------------------
# 1. Створіть ключ: https://platform.openai.com/api-keys
# 2. У корені проєкту скопіюйте цей файл:
#      cp .env.example .env
# 3. Відкрийте .env у редакторі та вставте свій ключ замість placeholder нижче.
#    Файл .env не комітиться в git (див. .gitignore) — туди кладуть лише секрети.
#
# Формат: одна змінна на рядок, без лапок навколо значення (або з лапками, якщо
#         у значенні є пробіли — dotenv це підтримує).
# ---------------------------------------------------------------------------

OPENAI_API_KEY=sk-замініть-на-ваш-реальний-ключ
